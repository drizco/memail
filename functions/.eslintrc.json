{
  "parserOptions": {
    "ecmaVersion": 2018
  },
  "env": {
    "es6": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "plugins": ["promise"],
  "rules": {
    "no-console": "off",
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-debugger": "off",
    "no-mixed-spaces-and-tabs": "off",
    "eqeqeq": "error",
    "no-eval": "error",
    "promise/always-return": "error",
    "promise/catch-or-return": "error"
  }
}

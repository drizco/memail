{
  "manifest_version": 3,

  "name": "MEmail",
  "version": "4.0",
  "description": "Email yourself links to sites you'd like to view later, in a single click!",
  "icons": {
    "16": "memail_logo@16px.png",
    "48": "memail_logo@48px.png",
    "128": "memail_logo@128px.png"
  },
  "action": {
    "default_icon": "memail_logo@128px.png",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "identity"
  ],
  "host_permissions": [
    "https://us-central1-memail-163415.cloudfunctions.net/*"
  ]
}
